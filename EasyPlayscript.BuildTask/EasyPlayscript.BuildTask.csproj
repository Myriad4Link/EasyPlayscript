<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>netstandard2.0</TargetFramework>
        <LangVersion>latest</LangVersion>
        <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>

        <IsPackable>true</IsPackable>
        <PackageId>EasyPlayscript.BuildTask</PackageId>
        <Version>1.0.0</Version>
        <Authors>EasyPlayscript</Authors>
        <Description>MSBuild task for compiling EasyPlayscript .scpt files</Description>
        <BuildOutputTargetFolder>tools</BuildOutputTargetFolder>
        <SuppressDependenciesWhenPacking>false</SuppressDependenciesWhenPacking>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\EasyPlayscript.Core\EasyPlayscript.Core.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="JetBrains.Annotations" Version="2026.2.0"/>
        <PackageReference Include="Microsoft.Build.Utilities.Core" Version="18.7.1" PrivateAssets="all"/>
    </ItemGroup>

    <ItemGroup>
        <None Include="build\*.targets" Pack="true" PackagePath="build\"/>
        <None Include="build\*.targets" Pack="true" PackagePath="buildTransitive\"/>
        <None Include="$(OutputPath)\EasyPlayscript.Core.dll" Pack="true" PackagePath="tools/netstandard2.0/" Visible="false"/>
        <None Include="$(OutputPath)\Antlr4.Runtime.Standard.dll" Pack="true" PackagePath="tools/netstandard2.0/" Visible="false"/>
        <None Include="$(OutputPath)\MessagePack.dll" Pack="true" PackagePath="tools/netstandard2.0/" Visible="false"/>
        <None Include="$(OutputPath)\MessagePack.Annotations.dll" Pack="true" PackagePath="tools/netstandard2.0/" Visible="false"/>
    </ItemGroup>

</Project>
